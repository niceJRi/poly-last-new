# ── Polymarket credentials (required for real mode) ─────────────────────────
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_BUILDER_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLYMARKET_BUILDER_SECRET=...
POLYMARKET_BUILDER_PASSPHRASE=...

# ── Trading parameters ───────────────────────────────────────────────────────
# USDC to spend per market after winner is confirmed (e.g. 10 means $10)
ORDER_USDC=10.0

# Price slippage buffer added on top of best ask when placing orders
SLIPPAGE_BUFFER=0.02

# Market kind: btc-5m | btc-15m | eth-5m | eth-15m
MARKET=btc-5m

# Max trades to place per market (0 = unlimited)
MAX_TRADES_PER_MARKET=3

# ── Chainlink Data Streams (required for accurate beat/current price) ────────
# Get credentials: https://data.chain.link → Connect Wallet → API Keys
# Feed IDs are hardcoded per asset (btc-usd-cexprice-streams / eth-usd-cexprice-streams)
# Without these the bot falls back to the on-chain aggregator (lags ~30s–5min)
CHAINLINK_DS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CHAINLINK_DS_API_SECRET=...

# ── Polygon RPC for Chainlink aggregator fallback ────────────────────────────
# Leave blank to use the default public RPC
POLYGON_RPC_URL=https://polygon-rpc.com
