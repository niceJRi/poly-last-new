# ── Polymarket credentials (required for real mode, not needed for test) ─────
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_BUILDER_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLYMARKET_BUILDER_SECRET=...
POLYMARKET_BUILDER_PASSPHRASE=...

# ── Market ────────────────────────────────────────────────────────────────────
# btc-5m | btc-15m | eth-5m | eth-15m
MARKET=btc-5m

# ── Trading parameters ────────────────────────────────────────────────────────
# USDC to spend on one trade attempt after the winner is confirmed.
# Example: 10 means the bot spends up to $10 per post-market window.
TRADE_AMOUNT=10.0

# Maximum number of individual orders to place per market (0 = unlimited).
# Set to 1 to buy once then stop, even if budget remains.
MAX_TRADES=3

# Extra price buffer added on top of the best ask when placing orders.
# Helps ensure fills; 0.02 = 2 cents on a $0.98 ask → submit at $1.00 max.
SLIPPAGE_BUFFER=0.02
